# Home App - Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase Configuration (Required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe Configuration (Required for Premium Features)
# OPTION 1: MOCK MODE (for development - no real payments)
NEXT_PUBLIC_MOCK_STRIPE=true

# OPTION 2: REAL STRIPE (for production)
# Remove or set NEXT_PUBLIC_MOCK_STRIPE=false when using real Stripe
# STRIPE_SECRET_KEY=sk_test_... or sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_... or pk_live_...
# STRIPE_PRICE_ID=price_... # The price ID for your $5/month subscription
# STRIPE_WEBHOOK_SECRET=whsec_... # For webhook verification

# Application Configuration
NEXT_PUBLIC_BASE_URL=https://your-domain.vercel.app
# For local development, use: http://localhost:3000
